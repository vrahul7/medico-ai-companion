# ============================================================
# Medico AI Companion — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to version control.
# ============================================================

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini / Generative AI
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# NCBI / PubMed (increases rate limit from 3 to 10 req/sec)
NCBI_API_KEY=your_ncbi_api_key_here
ENTREZ_EMAIL=your_email@example.com

# Pinecone Vector Database
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=medico-ai-companion

# ─── WhatsApp Bot (Twilio Sandbox) ─────────────────────────
# Get from: https://console.twilio.com → Messaging → Try WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Webhook verification token (any secret string)
WHATSAPP_VERIFY_TOKEN=your_verify_token_here

# Approved doctors — E.164 format, comma-separated (no spaces)
# Example: +919876543210,+918765432109
WHATSAPP_APPROVED_NUMBERS=+91XXXXXXXXXX
