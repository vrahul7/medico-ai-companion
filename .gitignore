# ============================================================
# Medico AI Companion — .gitignore
# SECURITY: Never commit API keys, secrets, or patient data
# ============================================================

# ---- Environment & Secrets (NEVER commit these) ----
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials/

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Node / Frontend ----
node_modules/
dist/
dist-ssr/
*.local

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- Medical Data & Vector DB (large / sensitive) ----
# PDFs are large copyrighted textbooks — store in cloud storage or DVC
backend/data/
*.pdf
*.chroma/
chroma_db/
pinecone_cache/

# ---- Editor & OS ----
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- Antigravity Agent internals ----
.agents/

# ---- Temp / Office lock files ----
~$*

# ---- Build artifacts ----
*.pyc
*.pyo
